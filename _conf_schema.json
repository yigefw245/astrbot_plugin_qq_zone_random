{
    "admin_uins": {
        "description": "管理员QQ号，多个用英文逗号分隔；留空允许所有人使用",
        "type": "string",
        "hint": "例如: 123456,789012"
    },
    "provider_id": {
        "description": "AI生成说说的LLM提供商ID",
        "type": "string",
        "hint": "留空则使用当前会话默认提供商。填写如 openai、deepseek 等",
        "default": ""
    },
    "schedule": {
        "description": "定时发送配置",
        "type": "object",
        "items": {
            "enabled": {
                "description": "是否启用定时发送",
                "type": "bool",
                "default": false
            },
            "start_hour": {
                "description": "每天开始时间（小时，0-23）",
                "type": "int",
                "hint": "例如 9 表示早上9点开始",
                "default": 9
            },
            "end_hour": {
                "description": "每天结束时间（小时，0-23）",
                "type": "int",
                "hint": "例如 22 表示晚上10点结束。不能小于开始时间",
                "default": 22
            },
            "min_posts": {
                "description": "每天最少发送条数（允许为0）",
                "type": "int",
                "hint": "0 表示可以不发",
                "default": 0
            },
            "max_posts": {
                "description": "每天最多发送条数",
                "type": "int",
                "hint": "不能小于最少条数。建议 1-10",
                "default": 3
            }
        }
    }
}